# GridPulse AI — Environment Variables
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — never commit secrets.

# ── Database ───────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gridpulse

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=30

# ── Application ────────────────────────────────────────────────────────────────
DEBUG=false
APP_NAME=GridPulse AI
APP_VERSION=1.0.0

# Comma-separated list of origins allowed by CORS (no trailing slash)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Ingestion limits ───────────────────────────────────────────────────────────
MAX_BATCH_SIZE=500

# ── Simulator ──────────────────────────────────────────────────────────────────
SIMULATOR_TARGET_URL=http://localhost:8000/api/v1/telemetry
SIMULATOR_NUM_METERS=20
SIMULATOR_INTERVAL_S=0.5
SIMULATOR_BATCH_SIZE=10

# ── ML Forecaster ───────────────────────────────────────────────────────────────
# Set ENABLE_LSTM=true to activate the PyTorch LSTM forecaster instead of the
# default GridForecaster (Ridge regression).
# LSTM_WEIGHTS_PATH can be relative (to project root) or absolute.
# Generate weights with: python train_lstm.py
ENABLE_LSTM=false
LSTM_WEIGHTS_PATH=lstm_load_weights.pth
ENABLE_GRID_FORECASTER=true
